generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ProductType {
  COURSE
  EBOOK
  MENTORSHIP
  CONSULTING
  COMMUNITY
}

enum TaskStage {
  MARKET_ANALYSIS
  COPY
  DESIGN
  DEVELOPMENT
  REVIEW
  PUBLISHED
}

model Expert {
  id        String    @id @default(cuid())
  name      String
  niche     String
  instagram String    @default("")
  youtube   String    @default("")
  email     String    @default("")
  notes     String    @default("")
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id                     String      @id @default(cuid())
  name                   String
  type                   ProductType
  price                  Float
  targetAudience         String
  mainPain               String
  promisedTransformation String
  notes                  String      @default("")
  expertId               String
  createdAt              DateTime    @default(now())
  expert                 Expert      @relation(fields: [expertId], references: [id], onDelete: Cascade)
  tasks                  Task[]
  copy                   Copy?
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  stage       TaskStage @default(MARKET_ANALYSIS)
  responsible String    @default("")
  productId   String
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Copy {
  id          String   @id @default(cuid())
  headline    String
  subheadline String
  benefits    String
  audience    String
  cta         String
  faq         String
  productId   String   @unique
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
